---
import siteZh from '../data/content/site.zh.json';
import siteEn from '../data/content/site.en.json';

import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/components.css';
import '../styles/utilities.css';

import revealScript from '../scripts/reveal.mjs?url';
import uiScript from '../scripts/ui.mjs?url';

const {
  title = 'Lab Website',
  desc = 'Local-first Astro lab website prototype',
  lang = 'zh',
  pathPrefix = ''
} = Astro.props as { title?: string; desc?: string; lang?: 'zh' | 'en'; pathPrefix?: string };

const t = lang === 'en' ? siteEn : siteZh;
const navPath = {
  home: `${pathPrefix}/`,
  members: `${pathPrefix}/members`,
  projects: `${pathPrefix}/projects`,
  papers: `${pathPrefix}/papers`,
  news: `${pathPrefix}/news`
};
---
<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <div class="brand">{t.brand}</div>
        <nav class="nav-links">
          <a class={`nav-link ${Astro.url.pathname === navPath.home ? 'is-active' : ''}`} href={navPath.home}>{t.nav.home}</a>
          <a class={`nav-link ${Astro.url.pathname.startsWith(navPath.members) ? 'is-active' : ''}`} href={navPath.members}>{t.nav.members}</a>
          <a class={`nav-link ${Astro.url.pathname.startsWith(navPath.projects) ? 'is-active' : ''}`} href={navPath.projects}>{t.nav.projects}</a>
          <a class={`nav-link ${Astro.url.pathname.startsWith(navPath.papers) ? 'is-active' : ''}`} href={navPath.papers}>{t.nav.papers}</a>
          <a class={`nav-link ${Astro.url.pathname.startsWith(navPath.news) ? 'is-active' : ''}`} href={navPath.news}>{t.nav.news}</a>
        </nav>
        <div class="nav-actions">
          <button class="btn btn-ghost" data-theme-toggle type="button" aria-label="Switch theme">Theme</button>
        </div>
      </div>
    </header>

    <main class="container site-shell">
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <span>Local-first preview · Astro static baseline</span>
        <span class="lang-switch"><a href="/">中文</a> / <a href="/en/">English</a></span>
      </div>
    </footer>

    <script type="module" src={revealScript}></script>
    <script type="module" src={uiScript}></script>
  </body>
</html>
