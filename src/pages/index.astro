---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteZh from '../data/site.zh.json';
import { getCollection } from 'astro:content';
import { buildLocalizedProjects, projectDisplayMeta } from '../utils/projects-localized';

const t = siteZh;
const projectEntries = await getCollection('projects');
const recentProjects = buildLocalizedProjects(projectEntries)
  .filter((item) => item.entry.overview.zh)
  .slice(0, 3);
const highlightLinks = ['/projects', '/papers', '/join'];

function resolveProjectStatusTone(status: string) {
  const value = (status || '').toLowerCase();
  if (value.includes('已完成') || value.includes('毕业') || value.includes('离开') || value.includes('completed')) {
    return 'former';
  }
  if (value.includes('进行中') || value.includes('在读') || value.includes('在职') || value.includes('ongoing') || value.includes('active')) {
    return 'current';
  }
  return '';
}
---
<BaseLayout title="首页" lang="zh" pathPrefix="">
  <section class="card hero hero-glow gradient-frame mb-5" data-reveal>
    <h1 class="hero-title" data-reveal data-reveal-delay="70">{t.siteName}</h1>
    <p class="hero-subtitle" data-reveal data-reveal-delay="120">{t.home.intro}</p>
    <div class="hero-actions" data-reveal data-reveal-delay="180">
      <a class="btn btn-primary" href="/papers">查看论文</a>
      <a class="btn btn-ghost" href="/projects">查看项目</a>
      <a class="btn btn-ghost" href="/members">了解成员</a>
    </div>
  </section>

  <section class="mb-5">
    <div class="page-head" data-reveal>
      <h2 class="page-title">{t.home.sections?.highlights ?? '重点信息'}</h2>
    </div>
    <div class="grid grid-3" data-reveal-group>
      {t.home.highlights.map((h, i) => (
        <article class="card card-hover card-clickable" data-reveal data-reveal-order={String(i)}>
          <a class="card-link-overlay" href={highlightLinks[i] ?? '/news'} aria-label={`查看 ${h.title} 详情`}></a>
          <h3>{h.title}</h3>
          <p class="mt-4">{h.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mb-5">
    <div class="page-head" data-reveal>
      <h2 class="page-title">{t.home.sections?.recentProjects ?? t.home.sections?.featuredProjects ?? '最近项目'}</h2>
    </div>
    <div class="grid grid-3" data-reveal-group>
      {recentProjects.map((item, i) => {
        const p = projectDisplayMeta(item, 'zh');
        return (
        <article class="card card-hover card-clickable stack-sm" data-reveal data-reveal-order={String(i)}>
          <a class="card-link-overlay" href={`/projects/${item.slug}/`} aria-label={`查看项目 ${p.title}`}></a>
          <h3>{p.title}</h3>
          <div class="meta">
            <span class="badge">{p.tag}</span>
            <span class={`status-chip status-${resolveProjectStatusTone(p.status)}`}>{p.status}</span>
          </div>
          <p>聚焦于 {p.tag} 方向，当前阶段：{p.status}。</p>
        </article>
      )})}
    </div>
  </section>

  <section class="card" data-reveal>
    <h2>{t.home.quick}</h2>
    <ul class="quick-links">
      <li><a href="/members">成员列表</a></li>
      <li><a href="/projects">项目展示</a></li>
      <li><a href="/papers">论文列表</a></li>
      <li><a href="/news">新闻动态</a></li>
    </ul>
  </section>
</BaseLayout>
