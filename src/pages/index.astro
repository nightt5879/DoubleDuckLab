---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteZh from '../data/content/site.zh.json';
import projects from '../data/content/projects.json';

const t = siteZh;
const featuredProjects = projects.slice(0, 3).map((p) => ({
  ...p,
  slug: p.slug ?? p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''),
}));
const highlightLinks = ['/projects', '/papers', '/join'];
---
<BaseLayout title="Lab Website · 首页" lang="zh" pathPrefix="">
  <section class="card hero hero-glow gradient-frame mb-5" data-reveal>
    <h1 class="hero-title" data-reveal data-reveal-delay="70">{t.home.title}</h1>
    <p class="hero-subtitle" data-reveal data-reveal-delay="120">{t.home.intro}</p>
    <div class="hero-actions" data-reveal data-reveal-delay="180">
      <a class="btn btn-primary" href="/projects">查看项目</a>
      <a class="btn btn-ghost" href="/members">了解成员</a>
    </div>
  </section>

  <section class="mb-5">
    <div class="page-head" data-reveal>
      <h2 class="page-title">Highlights</h2>
    </div>
    <div class="grid grid-3" data-reveal-group>
      {t.home.highlights.map((h, i) => (
        <article class="card card-hover card-clickable" data-reveal data-reveal-order={String(i)}>
          <a class="card-link-overlay" href={highlightLinks[i] ?? '/news'} aria-label={`查看 ${h.title} 详情`}></a>
          <h3>{h.title}</h3>
          <p class="mt-4">{h.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mb-5">
    <div class="page-head" data-reveal>
      <h2 class="page-title">Featured Projects</h2>
    </div>
    <div class="grid grid-3" data-reveal-group>
      {featuredProjects.map((p, i) => (
        <article class="card card-hover card-clickable stack-sm" data-reveal data-reveal-order={String(i)}>
          <a class="card-link-overlay" href={`/projects/${p.slug}/`} aria-label={`查看项目 ${p.title}`}></a>
          <h3>{p.title}</h3>
          <div class="meta">
            <span class="badge">{p.tag}</span>
            <span class="badge-muted">{p.status.zh}</span>
          </div>
          <p>聚焦于 {p.tag} 方向，当前阶段：{p.status.zh}。</p>
        </article>
      ))}
    </div>
  </section>

  <section class="card" data-reveal>
    <h2>{t.home.quick}</h2>
    <ul class="quick-links">
      <li><a href="/members">成员列表</a></li>
      <li><a href="/projects">项目展示</a></li>
      <li><a href="/papers">论文列表</a></li>
      <li><a href="/news">新闻动态</a></li>
    </ul>
  </section>
</BaseLayout>
