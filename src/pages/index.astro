---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteZh from '../data/content/site.zh.json';
const t = siteZh;
---
<BaseLayout title="Lab Website · 首页" lang="zh" pathPrefix="">
  <section class="card" style="margin-bottom:14px;">
    <span class="badge">{t.home.badge}</span>
    <h1 style="margin:10px 0 8px;">{t.home.title}</h1>
    <p style="color:var(--muted);line-height:1.7;">{t.home.intro}</p>
  </section>

  <section class="grid grid-3" style="margin-bottom:14px;">
    {t.home.highlights.map((h) => (
      <article class="card"><h3>{h.title}</h3><p style="color:var(--muted)">{h.desc}</p></article>
    ))}
  </section>

  <section class="card">
    <h2>{t.home.quick}</h2>
    <ul>
      <li><a href="/members">成员列表</a></li>
      <li><a href="/projects">项目展示</a></li>
      <li><a href="/papers">论文列表</a></li>
      <li><a href="/news">新闻动态</a></li>
    </ul>
  </section>
</BaseLayout>
