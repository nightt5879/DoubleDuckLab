---
import BaseLayout from '../layouts/BaseLayout.astro';
import members from '../data/content/members.json';
---
<BaseLayout title="Lab Website · 成员" lang="zh" pathPrefix="">
  <h1>成员列表</h1>
  <div class="grid grid-3">
    {members.map(m => (
      <article class="card">
        <h3>{m.name}</h3>
        <p style="color:var(--muted)">{m.role.zh}</p>
        <p>{m.area}</p>
      </article>
    ))}
  </div>
</BaseLayout>
