---
import BaseLayout from '../layouts/BaseLayout.astro';
const members = [
  { name: 'Prof. Zhang', role: 'PI', area: 'HCI + Robotics' },
  { name: 'Alice', role: 'PhD', area: 'Vision-Language Agents' },
  { name: 'Bob', role: 'Master', area: 'Embodied Planning' },
  { name: 'Carol', role: 'RA', area: 'Human-in-the-loop System' },
];
---
<BaseLayout title="Lab Website · Members">
  <h1>成员列表</h1>
  <div class="grid grid-3">
    {members.map(m => (
      <article class="card">
        <h3>{m.name}</h3>
        <p style="color:var(--muted)">{m.role}</p>
        <p>{m.area}</p>
      </article>
    ))}
  </div>
</BaseLayout>
