---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const newsEntries = await getCollection('news');
const news = newsEntries
  .map((e) => ({ date: e.data.date, title: e.data.title.zh }))
  .sort((a, b) => b.date.localeCompare(a.date));
---
<BaseLayout title="Lab Website · 新闻" lang="zh" pathPrefix="">
  <section class="page-head" data-reveal>
    <h1 class="page-title">新闻动态</h1>
    <p class="page-subtitle">近期更新按时间倒序排列，信息密度高但保持轻盈视觉。</p>
  </section>

  <div class="grid">
    {news.map((n, i) => (
      <article class="card card-hover stack-sm" data-reveal data-reveal-delay={String(i * 80)}>
        <h3>{n.title}</h3>
        <p>{n.date}</p>
      </article>
    ))}
  </div>
</BaseLayout>
