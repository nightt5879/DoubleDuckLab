---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const newsEntries = await getCollection('news');
const news = newsEntries
  .map((e) => ({
    slug: e.slug,
    date: e.data.date,
    title: e.data.title.zh,
    contex: e.data.contex?.zh ?? ''
  }))
  .sort((a, b) => b.date.localeCompare(a.date));
---
<BaseLayout title="Lab Website · 新闻" lang="zh" pathPrefix="">
  <section class="page-head" data-reveal>
    <h1 class="page-title">新闻动态</h1>
    <p class="page-subtitle">近期更新按时间倒序排列，信息密度高但保持轻盈视觉。</p>
  </section>

  <div class="grid">
    {news.map((n, i) => (
      <a href={`/news/${n.slug}/`} class="card card-hover card-link stack-sm" data-reveal data-reveal-order={String(i)}>
        <h3>{n.title}</h3>
        <p>{n.date}</p>
        {n.contex && (
          <div class="news-contex">
            <p>{n.contex}</p>
          </div>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
