---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildLocalizedProjects, projectDisplayMeta } from '../utils/projects-localized';

const projectEntries = await getCollection('projects');
const projects = buildLocalizedProjects(projectEntries).filter((item) => item.entry.overview.zh);

function resolveProjectStatusTone(status: string) {
  const value = (status || '').toLowerCase();
  if (value.includes('已完成') || value.includes('毕业') || value.includes('离开') || value.includes('completed')) {
    return 'former';
  }
  if (value.includes('进行中') || value.includes('在读') || value.includes('在职') || value.includes('ongoing') || value.includes('active')) {
    return 'current';
  }
  return '';
}

function formatPreviewTimeRange(value: string) {
  const years = (value || '').match(/\d{4}/g) || [];
  if (!years.length) {
    return '';
  }
  const start = years[0];
  const end = years[1] || years[0];
  return `${start}-${end}`;
}
---
<BaseLayout title="项目" lang="zh" pathPrefix="">
  <section class="page-head" data-reveal>
    <h1 class="page-title">项目</h1>
  </section>

  <div
    class="grid grid-3 project-grid"
    data-reveal-group
    data-reveal-step="44"
    data-progressive-list
    data-initial-count="24"
    data-batch-size="12"
    data-remaining-threshold="12"
    data-trigger-distance="850"
    data-chunk-size="6"
  >
    {projects.map((item) => {
      const meta = projectDisplayMeta(item, 'zh');
      return (
        <a href={`/projects/${item.slug}/`} class="card card-hover card-link stack-sm" data-progressive-item data-reveal>
          <h3>{meta.title}</h3>
          <div class="meta">
            {meta.time && <span class="badge-muted">{formatPreviewTimeRange(meta.time)}</span>}
            {meta.status && <span class={`status-chip status-${resolveProjectStatusTone(meta.status)}`}>{meta.status}</span>}
          </div>
        </a>
      );
    })}
  </div>
</BaseLayout>
