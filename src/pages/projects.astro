---
import BaseLayout from '../layouts/BaseLayout.astro';
import projects from '../data/content/projects.json';

const projectsWithSlug = projects.map((p) => ({
  ...p,
  slug: p.slug ?? p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''),
}));
---
<BaseLayout title="项目" lang="zh" pathPrefix="">
  <section class="page-head" data-reveal>
    <h1 class="page-title">项目</h1>
    <p class="page-subtitle">课题组重点方向与阶段状态一览。</p>
  </section>

  <div class="grid grid-3" data-reveal-group>
    {projectsWithSlug.map((p, i) => (
      <a href={`/projects/${p.slug}/`} class="card card-hover card-link stack-sm" data-reveal data-reveal-order={String(i)}>
        <h3>{p.title}</h3>
        <div class="meta">
          <span class="badge">{p.tag}</span>
          <span class="badge-muted">{p.status.zh}</span>
        </div>
        <p>项目状态：{p.status.zh}</p>
      </a>
    ))}
  </div>
</BaseLayout>
