---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildLocalizedProjects, projectDisplayMeta } from '../utils/projects-localized';

const projectEntries = await getCollection('projects');
const projects = buildLocalizedProjects(projectEntries).filter((item) => item.entry.overview.zh);
---
<BaseLayout title="项目" lang="zh" pathPrefix="">
  <section class="page-head" data-reveal>
    <h1 class="page-title">项目</h1>
    <p class="page-subtitle">课题组重点方向与阶段状态一览。</p>
  </section>

  <div class="grid grid-3" data-reveal-group>
    {projects.map((item, i) => {
      const meta = projectDisplayMeta(item, 'zh');
      return (
        <a href={`/projects/${item.slug}/`} class="card card-hover card-link stack-sm" data-reveal data-reveal-order={String(i)}>
          <h3>{meta.title}</h3>
          <div class="meta">
            {meta.tag && <span class="badge">{meta.tag}</span>}
            {meta.status && <span class="badge-muted">{meta.status}</span>}
          </div>
        </a>
      );
    })}
  </div>
</BaseLayout>
