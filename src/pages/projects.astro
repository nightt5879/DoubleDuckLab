---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/content';
---
<BaseLayout title="Lab Website · 项目" lang="zh" pathPrefix="">
  <h1>项目</h1>
  <div class="grid grid-3">
    {projects.map(p => (
      <article class="card">
        <h3>{p.title}</h3>
        <p><span class="badge">{p.tag}</span></p>
        <p style="color:var(--muted)">状态：{p.status.zh}</p>
      </article>
    ))}
  </div>
</BaseLayout>
