---
import BaseLayout from '../layouts/BaseLayout.astro';
import projects from '../data/content/projects.json';
---
<BaseLayout title="Lab Website · 项目" lang="zh" pathPrefix="">
  <section class="page-head" data-reveal>
    <h1 class="page-title">项目</h1>
    <p class="page-subtitle">课题组重点方向与阶段状态一览。</p>
  </section>

  <div class="grid grid-3">
    {projects.map((p, i) => (
      <article class="card card-hover stack-sm" data-reveal data-reveal-delay={String(i * 90)}>
        <h3>{p.title}</h3>
        <div class="meta">
          <span class="badge">{p.tag}</span>
          <span class="badge-muted">{p.status.zh}</span>
        </div>
        <p>项目状态：{p.status.zh}</p>
      </article>
    ))}
  </div>
</BaseLayout>
