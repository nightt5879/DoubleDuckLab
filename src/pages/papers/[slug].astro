---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { summarizeParts } from '../../utils/seo';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const abstract = entry.data.abstract?.trim() ?? '';
const bibtex = entry.data.bibtex?.trim() ?? '';
const links = entry.data.links;
const hasLinks = Boolean(links?.online || links?.pdf || links?.project || links?.code);
const hasBody = Boolean(entry.body?.trim());
const { Content } = await render(entry);
const pageDesc = abstract || summarizeParts([entry.data.authors, entry.data.venue, entry.data.year], 160);
---
<BaseLayout title={entry.data.title} desc={pageDesc} lang="zh" pathPrefix="" ogType="article">
  <section class="detail-shell">
    <article class="card detail-hero" data-reveal>
      <h1 class="page-title">{entry.data.title}</h1>
      <div class="detail-meta">
        <span class="badge">{entry.data.venue}</span>
        <span class="badge-muted">{entry.data.year}</span>
      </div>
      {entry.data.authors && <p class="paper-authors">作者：{entry.data.authors}</p>}
    </article>

    {abstract && (
      <article class="card detail-section" data-reveal>
        <h2>摘要</h2>
        <p>{abstract}</p>
      </article>
    )}

    {hasLinks && (
      <article class="card detail-section" data-reveal>
        <h2>链接</h2>
        <div class="detail-links">
          {links?.online && <a class="btn btn-ghost" href={links.online} target="_blank" rel="noreferrer">在线阅读</a>}
          {links?.pdf && <a class="btn btn-ghost" href={links.pdf} target="_blank" rel="noreferrer">论文 PDF</a>}
          {links?.project && <a class="btn btn-ghost" href={links.project} target="_blank" rel="noreferrer">项目链接</a>}
          {links?.code && <a class="btn btn-ghost" href={links.code} target="_blank" rel="noreferrer">代码</a>}
        </div>
      </article>
    )}

    {bibtex && (
      <article class="card detail-section" data-reveal>
        <h2>引用</h2>
        <details class="bibtex-details">
          <summary>BibTeX</summary>
          <pre id={`bibtex-${entry.slug}`}><code>{bibtex}</code></pre>
        </details>
        <button
          class="btn btn-ghost copy-btn"
          type="button"
          data-copy-target={`bibtex-${entry.slug}`}
          data-copy-label="复制"
          data-copy-success="已复制"
        >
          复制
        </button>
      </article>
    )}

    {hasBody && (
      <article class="card detail-content" data-reveal>
        <Content />
      </article>
    )}

    <div class="back-row" data-reveal>
      <a class="btn btn-primary" href="/papers" data-history-back>返回论文列表</a>
      <a class="btn btn-ghost" href="/">回到首页</a>
    </div>
  </section>
</BaseLayout>
