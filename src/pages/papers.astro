---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const paperEntries = await getCollection('papers');
const papers = paperEntries
  .map((e) => ({ slug: e.slug, ...e.data }))
  .sort((a, b) => b.year - a.year || a.title.localeCompare(b.title));
---
<BaseLayout title="论文" lang="zh" pathPrefix="">
  <section class="page-head" data-reveal>
    <h1 class="page-title">论文</h1>
  </section>

  <section class="filter-wrap" data-list-filter-root data-reveal>
    <input
      class="filter-input"
      type="search"
      data-list-search
      placeholder="搜索标题 / 作者 / 会议 / 年份..."
      aria-label="搜索论文"
    />
    <p class="empty-state" data-empty-state hidden>没有匹配论文，请调整关键词。</p>

  <div
    class="grid project-grid"
    data-list-intro
  >
    {papers.map((p, i) => (
      <a
        href={`/papers/${p.slug}/`}
        class="card card-hover card-link stack-sm"
        data-list-intro-item
        {...(i < 8 ? { 'data-list-intro-active': true } : {})}
        style={i < 8 ? `--list-intro-delay: ${(i % 4) * 40}ms;` : undefined}
        data-list-card
        data-search-text={`${p.title} ${p.authors || ''} ${p.venue} ${p.year}`}
      >
        <h3>{p.title}</h3>
        <p>{p.year} · {p.venue}</p>
        {p.authors && <p class="paper-authors">作者：{p.authors}</p>}
      </a>
    ))}
  </div>
  </section>
</BaseLayout>
