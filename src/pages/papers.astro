---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const paperEntries = await getCollection('papers');
const papers = paperEntries
  .map((e) => ({ slug: e.slug, ...e.data }))
  .sort((a, b) => b.year - a.year || a.title.localeCompare(b.title));
---
<BaseLayout title="论文" lang="zh" pathPrefix="">
  <section class="page-head" data-reveal>
    <h1 class="page-title">论文</h1>
  </section>

  <div class="grid">
    {papers.map((p, i) => (
      <a href={`/papers/${p.slug}/`} class="card card-hover card-link stack-sm" data-reveal data-reveal-order={String(i)}>
        <h3>{p.title}</h3>
        <p>{p.year} · {p.venue}</p>
      </a>
    ))}
  </div>
</BaseLayout>
