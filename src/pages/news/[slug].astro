---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { buildLocalizedNews } from '../../utils/news-localized';
import { summarizeParts } from '../../utils/seo';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  const localized = buildLocalizedNews(allNews).filter((item) => item.entry.zh);

  return localized
    .filter((item) => item.entry.zh)
    .map((item) => ({
      params: { slug: item.slug },
      props: {
        entry: item.entry.zh!,
        title: item.title.zh || item.title.en || item.slug,
        date: item.date,
        related: localized
          .filter((n) => n.slug !== item.slug)
          .slice(0, 3)
          .map((n) => ({
            slug: n.slug,
            date: n.date,
            title: n.title.zh || n.title.en || n.slug,
          })),
      },
    }));
}

const { entry, title, date, related } = Astro.props;
const { Content } = await render(entry);
const pageDesc = summarizeParts([date, entry.body], 160) || `${title}${date ? ` · ${date}` : ''}`;
---
<BaseLayout title={title} desc={pageDesc} lang="zh" pathPrefix="" ogType="article">
  <section class="detail-shell">
    <article class="card detail-hero" data-reveal>
      <h1 class="page-title">{title}</h1>
      <div class="detail-meta">
        {date && <span class="badge-muted">{date}</span>}
      </div>
    </article>

    <article class="card detail-content news-article" data-reveal>
      <Content />
    </article>

    <article class="card detail-section" data-reveal>
      <h2>更多新闻</h2>
      <ul class="detail-list">
        {related.map((n) => (
          <li><a href={`/news/${n.slug}/`}>{n.title}</a> · {n.date}</li>
        ))}
      </ul>
    </article>

    <div class="back-row" data-reveal>
      <a class="btn btn-primary" href="/news" data-history-back>返回新闻列表</a>
      <a class="btn btn-ghost" href="/">回到首页</a>
    </div>
  </section>
</BaseLayout>
