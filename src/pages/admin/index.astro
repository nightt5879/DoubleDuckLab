---
import { getCmsRuntimeConfig } from '../../utils/cms-config';

const cms = getCmsRuntimeConfig();
const title = 'DoubleDuckLab CMS';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
      :root {
        color-scheme: light;
        font-family: "Segoe UI", "PingFang SC", sans-serif;
        background: #f5f3ee;
        color: #1d1d1d;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top right, rgba(177, 127, 65, 0.18), transparent 26rem),
          linear-gradient(180deg, #fbfaf7 0%, #f0ebe1 100%);
      }

      main {
        max-width: 42rem;
        margin: 0 auto;
        padding: 4rem 1.5rem;
      }

      .card {
        background: rgba(255, 255, 255, 0.86);
        border: 1px solid rgba(29, 29, 29, 0.08);
        border-radius: 1.25rem;
        padding: 1.5rem;
        box-shadow: 0 20px 40px rgba(29, 29, 29, 0.08);
      }

      h1 {
        margin: 0 0 0.75rem;
        font-size: clamp(2rem, 5vw, 3rem);
      }

      p,
      li {
        line-height: 1.7;
      }

      code {
        background: rgba(29, 29, 29, 0.06);
        border-radius: 0.375rem;
        padding: 0.15rem 0.35rem;
      }

      .muted {
        color: #5e5a55;
      }

      ul {
        padding-left: 1.25rem;
      }
    </style>
  </head>
  <body>
    {cms.enabled ? (
      <>
        <main class="card">
          <h1>{title}</h1>
          <p class="muted">Loading Decap CMS for the `news` editorial workflow.</p>
          <p class="muted">Repository: <code>{cms.repo}</code></p>
        </main>
        <script src="https://unpkg.com/decap-cms@3.10.1/dist/decap-cms.js"></script>
      </>
    ) : (
      <main>
        <section class="card">
          <h1>CMS setup required</h1>
          <p>The `news` CMS is included in this template, but this build is missing the environment variables needed to point it at a real GitHub repository, OAuth proxy, and production site URL.</p>
          <p>Set the following variables and rebuild before using <code>/admin/</code>:</p>
          <ul>
            {cms.missing.map((item) => (
              <li><code>{item}</code></li>
            ))}
            <li><code>CMS_BRANCH</code> (optional, defaults to <code>main</code>)</li>
          </ul>
          <p class="muted">This page intentionally does not load Decap CMS until the build is fully configured.</p>
        </section>
      </main>
    )}
  </body>
</html>
