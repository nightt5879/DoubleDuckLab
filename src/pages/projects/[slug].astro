---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { buildLocalizedProjects, projectDisplayMeta } from '../../utils/projects-localized';
import { summarizeParts } from '../../utils/seo';

function resolveProjectStatusTone(status: string) {
  const value = (status || '').toLowerCase();
  if (value.includes('已完成') || value.includes('毕业') || value.includes('离开') || value.includes('completed')) {
    return 'former';
  }
  if (value.includes('进行中') || value.includes('在读') || value.includes('在职') || value.includes('ongoing') || value.includes('active')) {
    return 'current';
  }
  return '';
}

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  const localized = buildLocalizedProjects(allProjects).filter((item) => item.entry.overview.zh);

  return localized.map((item) => ({
    params: { slug: item.slug },
    props: {
      slug: item.slug,
      overviewEntry: item.entry.overview.zh!,
      backgroundEntry: item.entry.background.zh,
      fallbackBackgroundEntry: item.entry.background.en,
      meta: projectDisplayMeta(item, 'zh'),
    },
  }));
}

const { overviewEntry, backgroundEntry, fallbackBackgroundEntry, meta } = Astro.props;
const { Content: OverviewContent } = await render(overviewEntry);
const bgEntry = backgroundEntry || fallbackBackgroundEntry;
const bgRender = bgEntry ? await render(bgEntry) : null;
const BackgroundContent = bgRender?.Content;

const links = meta.links || {};
const hasLinks = Boolean(links.repo || links.demo || links.paper);
const pageDesc =
  summarizeParts([meta.tag, meta.status, meta.time, overviewEntry.body], 160) || '查看 DoubleDuckLab 项目详情。';
---
<BaseLayout title={meta.title} desc={pageDesc} lang="zh" pathPrefix="">
  <section class="detail-shell">
    <article class="card detail-hero" data-reveal>
      <h1 class="page-title">{meta.title}</h1>
      <div class="detail-meta">
        {meta.time && <span class="badge-muted">{meta.time}</span>}
        {meta.status && <span class={`status-chip status-${resolveProjectStatusTone(meta.status)}`}>{meta.status}</span>}
      </div>
    </article>

    <article class="card detail-section" data-reveal>
      <h2>项目概览</h2>
      <div class="detail-content news-article">
        <OverviewContent />
      </div>
    </article>

    {BackgroundContent && (
      <article class="card detail-section" data-reveal>
        <h2>背景与目标</h2>
        <div class="detail-content news-article">
          <BackgroundContent />
        </div>
      </article>
    )}

    {hasLinks && (
      <article class="card detail-section" data-reveal>
        <h2>链接</h2>
        <div class="detail-links">
          {links.repo && <a class="btn btn-ghost" href={links.repo} target="_blank" rel="noreferrer">代码仓库</a>}
          {links.demo && <a class="btn btn-ghost" href={links.demo} target="_blank" rel="noreferrer">演示</a>}
          {links.paper && <a class="btn btn-ghost" href={links.paper} target="_blank" rel="noreferrer">论文</a>}
        </div>
      </article>
    )}

    <div class="back-row" data-reveal>
      <a class="btn btn-primary" href="/projects" data-history-back>返回项目列表</a>
      <a class="btn btn-ghost" href="/">回到首页</a>
    </div>
  </section>
</BaseLayout>
