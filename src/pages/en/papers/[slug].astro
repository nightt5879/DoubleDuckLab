---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const abstract = entry.data.abstract?.trim() ?? '';
const bibtex = entry.data.bibtex?.trim() ?? '';
const links = entry.data.links;
const hasLinks = Boolean(links?.online || links?.pdf || links?.project || links?.code);
const hasBody = Boolean(entry.body?.trim());
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title} lang="en" pathPrefix="/en">
  <section class="detail-shell">
    <article class="card detail-hero" data-reveal>
      <h1 class="page-title">{entry.data.title}</h1>
      <div class="detail-meta">
        <span class="badge">{entry.data.venue}</span>
        <span class="badge-muted">{entry.data.year}</span>
      </div>
    </article>

    {abstract && (
      <article class="card detail-section" data-reveal>
        <h2>Abstract</h2>
        <p>{abstract}</p>
      </article>
    )}

    {hasLinks && (
      <article class="card detail-section" data-reveal>
        <h2>Links</h2>
        <div class="detail-links">
          {links?.online && <a class="btn btn-ghost" href={links.online} target="_blank" rel="noreferrer">Online</a>}
          {links?.pdf && <a class="btn btn-ghost" href={links.pdf} target="_blank" rel="noreferrer">Paper PDF</a>}
          {links?.project && <a class="btn btn-ghost" href={links.project} target="_blank" rel="noreferrer">Project Link</a>}
          {links?.code && <a class="btn btn-ghost" href={links.code} target="_blank" rel="noreferrer">Code</a>}
        </div>
      </article>
    )}

    {bibtex && (
      <article class="card detail-section" data-reveal>
        <h2>Citation</h2>
        <details class="bibtex-details">
          <summary>Citation (BibTeX)</summary>
          <pre id={`bibtex-${entry.slug}`}><code>{bibtex}</code></pre>
        </details>
        <button
          class="btn btn-ghost copy-btn"
          type="button"
          data-copy-target={`bibtex-${entry.slug}`}
          data-copy-label="Copy"
          data-copy-success="Copied"
        >
          Copy
        </button>
      </article>
    )}

    {hasBody && (
      <article class="card detail-content" data-reveal>
        <Content />
      </article>
    )}

    <div class="back-row" data-reveal>
      <a class="btn btn-primary" href="/en/papers">Back to Papers</a>
      <a class="btn btn-ghost" href="/en/">Back to Home</a>
    </div>
  </section>
</BaseLayout>
