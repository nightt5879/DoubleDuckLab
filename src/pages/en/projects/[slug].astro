---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { buildLocalizedProjects, projectDisplayMeta } from '../../../utils/projects-localized';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  const localized = buildLocalizedProjects(allProjects).filter((item) => item.entry.overview.en);

  return localized.map((item) => ({
    params: { slug: item.slug },
    props: {
      slug: item.slug,
      overviewEntry: item.entry.overview.en!,
      backgroundEntry: item.entry.background.en,
      fallbackBackgroundEntry: item.entry.background.zh,
      meta: projectDisplayMeta(item, 'en'),
    },
  }));
}

const { overviewEntry, backgroundEntry, fallbackBackgroundEntry, meta } = Astro.props;
const { Content: OverviewContent } = await render(overviewEntry);
const bgEntry = backgroundEntry || fallbackBackgroundEntry;
const bgRender = bgEntry ? await render(bgEntry) : null;
const BackgroundContent = bgRender?.Content;

const links = meta.links || {};
const hasLinks = Boolean(links.repo || links.demo || links.paper);
---
<BaseLayout title={meta.title} lang="en" pathPrefix="/en">
  <section class="detail-shell">
    <article class="card detail-hero" data-reveal>
      <h1 class="page-title">{meta.title}</h1>
      <div class="detail-meta">
        {meta.tag && <span class="badge">{meta.tag}</span>}
        {meta.time && <span class="badge-muted">{meta.time}</span>}
        {meta.status && <span class="badge-muted">{meta.status}</span>}
      </div>
    </article>

    <article class="card detail-section" data-reveal>
      <h2>Project Overview</h2>
      <div class="detail-content news-article">
        <OverviewContent />
      </div>
    </article>

    {BackgroundContent && (
      <article class="card detail-section" data-reveal>
        <h2>Background & Goal</h2>
        <div class="detail-content news-article">
          <BackgroundContent />
        </div>
      </article>
    )}

    {hasLinks && (
      <article class="card detail-section" data-reveal>
        <h2>Links</h2>
        <div class="detail-links">
          {links.repo && <a class="btn btn-ghost" href={links.repo} target="_blank" rel="noreferrer">Repo</a>}
          {links.demo && <a class="btn btn-ghost" href={links.demo} target="_blank" rel="noreferrer">Demo</a>}
          {links.paper && <a class="btn btn-ghost" href={links.paper} target="_blank" rel="noreferrer">Paper</a>}
        </div>
      </article>
    )}

    <div class="back-row" data-reveal>
      <a class="btn btn-primary" href="/en/projects">Back to Projects</a>
      <a class="btn btn-ghost" href="/en/">Back to Home</a>
    </div>
  </section>
</BaseLayout>
