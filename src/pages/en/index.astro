---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { dict } from '../../data/content';
const t = dict.en;
---
<BaseLayout title="Lab Website · Home" lang="en" pathPrefix="/en">
  <section class="card" style="margin-bottom:14px;">
    <span class="badge">{t.home.badge}</span>
    <h1 style="margin:10px 0 8px;">{t.home.title}</h1>
    <p style="color:var(--muted);line-height:1.7;">{t.home.intro}</p>
  </section>

  <section class="grid grid-3" style="margin-bottom:14px;">
    {t.home.highlights.map((h) => (
      <article class="card"><h3>{h.title}</h3><p style="color:var(--muted)">{h.desc}</p></article>
    ))}
  </section>

  <section class="card">
    <h2>{t.home.quick}</h2>
    <ul>
      <li><a href="/en/members">Members</a></li>
      <li><a href="/en/projects">Projects</a></li>
      <li><a href="/en/papers">Publications</a></li>
      <li><a href="/en/news">News</a></li>
    </ul>
  </section>
</BaseLayout>
