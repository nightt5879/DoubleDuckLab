---
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteEn from '../../data/site.en.json';
import { getCollection } from 'astro:content';
import { buildLocalizedProjects, projectDisplayMeta } from '../../utils/projects-localized';

const t = siteEn;
const projectEntries = await getCollection('projects');
const recentProjects = buildLocalizedProjects(projectEntries)
  .filter((item) => item.entry.overview.en)
  .slice(0, 3);
const highlightLinks = ['/en/projects', '/en/papers', '/en/join'];
---
<BaseLayout title="Home" lang="en" pathPrefix="/en">
  <section class="card hero hero-glow gradient-frame mb-5" data-reveal>
    <h1 class="hero-title" data-reveal data-reveal-delay="70">{t.siteName}</h1>
    <p class="hero-subtitle" data-reveal data-reveal-delay="120">{t.home.intro}</p>
    <div class="hero-actions" data-reveal data-reveal-delay="180">
      <a class="btn btn-primary" href="/en/papers">View Papers</a>
      <a class="btn btn-ghost" href="/en/projects">Explore Projects</a>
      <a class="btn btn-ghost" href="/en/members">Meet Members</a>
    </div>
  </section>

  <section class="mb-5">
    <div class="page-head" data-reveal>
      <h2 class="page-title">{t.home.sections?.highlights ?? 'Highlights'}</h2>
    </div>
    <div class="grid grid-3" data-reveal-group>
      {t.home.highlights.map((h, i) => (
        <article class="card card-hover card-clickable" data-reveal data-reveal-order={String(i)}>
          <a class="card-link-overlay" href={highlightLinks[i] ?? '/en/news'} aria-label={`View ${h.title}`}></a>
          <h3>{h.title}</h3>
          <p class="mt-4">{h.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mb-5">
    <div class="page-head" data-reveal>
      <h2 class="page-title">{t.home.sections?.recentProjects ?? t.home.sections?.featuredProjects ?? 'Recent Projects'}</h2>
    </div>
    <div class="grid grid-3" data-reveal-group>
      {recentProjects.map((item, i) => {
        const p = projectDisplayMeta(item, 'en');
        return (
        <article class="card card-hover card-clickable stack-sm" data-reveal data-reveal-order={String(i)}>
          <a class="card-link-overlay" href={`/en/projects/${item.slug}/`} aria-label={`View project ${p.title}`}></a>
          <h3>{p.title}</h3>
          <div class="meta">
            <span class="badge">{p.tag}</span>
            <span class="badge-muted">{p.status}</span>
          </div>
          <p>Focus area: {p.tag}. Current phase: {p.status}.</p>
        </article>
      )})}
    </div>
  </section>

  <section class="card" data-reveal>
    <h2>{t.home.quick}</h2>
    <ul class="quick-links">
      <li><a href="/en/members">Members</a></li>
      <li><a href="/en/projects">Projects</a></li>
      <li><a href="/en/papers">Publications</a></li>
      <li><a href="/en/news">News</a></li>
    </ul>
  </section>
</BaseLayout>
