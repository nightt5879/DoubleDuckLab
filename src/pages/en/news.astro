---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildLocalizedNews } from '../../utils/news-localized';

const newsEntries = await getCollection('news');
const news = buildLocalizedNews(newsEntries).filter((item) => item.entry.en);
---
<BaseLayout title="News" lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">News</h1>
  </section>

  <section class="filter-wrap" data-list-filter-root data-reveal>
    <input
      class="filter-input"
      type="search"
      data-list-search
      placeholder="Search title / date / keywords..."
      aria-label="Search news"
    />
    <p class="empty-state" data-empty-state hidden>No matching news found. Try another keyword.</p>

  <div class="grid" data-list-intro>
    {news.map((n, i) => (
      <a
        href={`/en/news/${n.slug}/`}
        class="card card-hover card-link stack-sm"
        data-list-intro-item
        data-list-card
        data-search-text={`${n.title.en || ''} ${n.title.zh || ''} ${n.date || ''} ${n.slug}`}
      >
        <h3>{n.title.en || n.title.zh || n.slug}</h3>
        {n.date && <p>{n.date}</p>}
      </a>
    ))}
  </div>
  </section>
</BaseLayout>
