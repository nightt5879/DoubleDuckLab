---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const newsEntries = await getCollection('news');
const news = newsEntries
  .map((e) => ({
    slug: e.slug,
    date: e.data.date,
    title: e.data.title.en,
    contex: e.data.contex?.en ?? ''
  }))
  .sort((a, b) => b.date.localeCompare(a.date));
---
<BaseLayout title="Lab Website · News" lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">News</h1>
  </section>

  <div class="grid">
    {news.map((n, i) => (
      <a href={`/en/news/${n.slug}/`} class="card card-hover card-link stack-sm" data-reveal data-reveal-order={String(i)}>
        <h3>{n.title}</h3>
        <p>{n.date}</p>
        {n.contex && (
          <div class="news-contex">
            <p>{n.contex}</p>
          </div>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
