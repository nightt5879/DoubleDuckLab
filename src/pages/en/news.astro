---
import BaseLayout from '../../layouts/BaseLayout.astro';
import news from '../../data/content/news.json';
---
<BaseLayout title="Lab Website · News" lang="en" pathPrefix="/en">
  <h1>News</h1>
  <div class="grid">
    {news.map(n => (
      <article class="card">
        <h3 style="margin-bottom:6px">{n.title.en}</h3>
        <p style="margin:0;color:var(--muted)">{n.date}</p>
      </article>
    ))}
  </div>
</BaseLayout>
