---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const newsEntries = await getCollection('news');
const news = newsEntries
  .map((e) => ({ date: e.data.date, title: e.data.title.en }))
  .sort((a, b) => b.date.localeCompare(a.date));
---
<BaseLayout title="Lab Website · News" lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">News</h1>
    <p class="page-subtitle">Recent updates, sorted by date with consistent cards and subtle reveal motion.</p>
  </section>

  <div class="grid">
    {news.map((n, i) => (
      <article class="card card-hover stack-sm" data-reveal data-reveal-delay={String(i * 80)}>
        <h3>{n.title}</h3>
        <p>{n.date}</p>
      </article>
    ))}
  </div>
</BaseLayout>
