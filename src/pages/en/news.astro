---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const newsEntries = await getCollection('news');
const news = newsEntries
  .map((e) => ({ date: e.data.date, title: e.data.title.en }))
  .sort((a, b) => b.date.localeCompare(a.date));
---
<BaseLayout title="Lab Website · News" lang="en" pathPrefix="/en">
  <h1>News</h1>
  <div class="grid">
    {news.map(n => (
      <article class="card">
        <h3 style="margin-bottom:6px">{n.title}</h3>
        <p style="margin:0;color:var(--muted)">{n.date}</p>
      </article>
    ))}
  </div>
</BaseLayout>
