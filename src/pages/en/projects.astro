---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/content/projects.json';

const projectsWithSlug = projects.map((p) => ({
  ...p,
  slug: p.slug ?? p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''),
}));
---
<BaseLayout title="Lab Website · Projects" lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">A concise view of key initiatives and current progress.</p>
  </section>

  <div class="grid grid-3" data-reveal-group>
    {projectsWithSlug.map((p, i) => (
      <a href={`/en/projects/${p.slug}/`} class="card card-hover card-link stack-sm" data-reveal data-reveal-order={String(i)}>
        <h3>{p.title}</h3>
        <div class="meta">
          <span class="badge">{p.tag}</span>
          <span class="badge-muted">{p.status.en}</span>
        </div>
        <p>Current status: {p.status.en}</p>
      </a>
    ))}
  </div>
</BaseLayout>
