---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildLocalizedProjects, projectDisplayMeta } from '../../utils/projects-localized';

const projectEntries = await getCollection('projects');
const projects = buildLocalizedProjects(projectEntries).filter((item) => item.entry.overview.en);
---
<BaseLayout title="Projects" lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">A concise view of key initiatives and current progress.</p>
  </section>

  <div class="grid grid-3" data-reveal-group>
    {projects.map((item, i) => {
      const meta = projectDisplayMeta(item, 'en');
      return (
        <a href={`/en/projects/${item.slug}/`} class="card card-hover card-link stack-sm" data-reveal data-reveal-order={String(i)}>
          <h3>{meta.title}</h3>
          <div class="meta">
            {meta.tag && <span class="badge">{meta.tag}</span>}
            {meta.status && <span class="badge-muted">{meta.status}</span>}
          </div>
        </a>
      );
    })}
  </div>
</BaseLayout>
