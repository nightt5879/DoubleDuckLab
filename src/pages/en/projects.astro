---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/content';
---
<BaseLayout title="Lab Website · Projects" lang="en" pathPrefix="/en">
  <h1>Projects</h1>
  <div class="grid grid-3">
    {projects.map(p => (
      <article class="card">
        <h3>{p.title}</h3>
        <p><span class="badge">{p.tag}</span></p>
        <p style="color:var(--muted)">Status: {p.status.en}</p>
      </article>
    ))}
  </div>
</BaseLayout>
