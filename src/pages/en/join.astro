---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Lab Website · Join & Collaborate" lang="en" pathPrefix="/en">
  <section class="detail-shell">
    <article class="card detail-hero" data-reveal>
      <span class="badge-muted">Join & Collaborate</span>
      <h1 class="page-title">Join & Collaborate</h1>
      <p>This template page demonstrates a complete CTA destination for recruitment and collaboration workflows.</p>
    </article>

    <article class="card detail-section" data-reveal>
      <h2>Open Positions (Template)</h2>
      <ul class="detail-list">
        <li>Undergraduate research interns with interests in HCI, robotics, and AI systems.</li>
        <li>MS/PhD applicants focused on embodied intelligence, multimodal agents, and evaluation pipelines.</li>
        <li>Joint supervision opportunities for cross-lab and cross-industry projects.</li>
      </ul>
    </article>

    <article class="card detail-section" data-reveal>
      <h2>Collaboration Modes (Template)</h2>
      <p>We support academic collaboration, industry co-research, and scenario-driven validation tracks.</p>
    </article>

    <article class="card detail-section" data-reveal>
      <h2>Contact (Template)</h2>
      <ul class="detail-list">
        <li>Email: join@example-lab.org</li>
        <li>Address: Intelligent Systems Lab, Building XX, 5F</li>
        <li>Office Hours: Weekdays 10:00 - 18:00 (appointment recommended)</li>
      </ul>
    </article>

    <div class="back-row" data-reveal>
      <a class="btn btn-primary" href="/en/">Back to Home</a>
      <a class="btn btn-ghost" href="/en/members">View Members</a>
    </div>
  </section>
</BaseLayout>
