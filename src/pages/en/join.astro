---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { summarizeText } from '../../utils/seo';

const joinEntries = await getCollection('join');
const entry =
  joinEntries.find((item) => item.id === 'recruitment/overview_en.md') ||
  joinEntries.find((item) => /_en\.md$/i.test(item.id));

if (!entry) {
  throw new Error('Missing English join content: src/content/join/**/_en.md');
}

const { Content } = await render(entry);
const pageTitle = entry.data.title || 'Recruitment & Collaboration';
const pageDesc = summarizeText(entry.body) || 'Explore recruitment and collaboration information for DoubleDuckLab.';
---
<BaseLayout title={pageTitle} desc={pageDesc} lang="en" pathPrefix="/en">
  <section class="detail-shell">
    <article class="card detail-hero" data-reveal>
      <h1 class="page-title">{pageTitle}</h1>
    </article>

    <article class="card detail-content news-article" data-reveal>
      <Content />
    </article>

    <div class="back-row" data-reveal>
      <a class="btn btn-primary" href="/en/">Back to Home</a>
      <a class="btn btn-ghost" href="/en/members">View Members</a>
    </div>
  </section>
</BaseLayout>
