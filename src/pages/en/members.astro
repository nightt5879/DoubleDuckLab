---
import BaseLayout from '../../layouts/BaseLayout.astro';
import members from '../../data/content/members.json';

const roles = ['All', ...Array.from(new Set(members.map((m) => m.role.en)))];

function initials(name: string) {
  const chunks = name.split(/\s+/).filter(Boolean);
  if (chunks.length >= 2) {
    return `${chunks[0][0] || ''}${chunks[chunks.length - 1][0] || ''}`.toUpperCase();
  }
  return (chunks[0] || 'M').slice(0, 2).toUpperCase();
}
---
<BaseLayout title="Lab Website · Members" lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">Members</h1>
    <p class="page-subtitle">Search by name/area keywords and refine results by role tags.</p>
  </section>

  <section class="filter-wrap" data-members-filter-root data-reveal>
    <input
      class="filter-input"
      type="search"
      data-member-search
      placeholder="Search name / area / role..."
      aria-label="Search members"
    />

    <div class="filter-tags">
      {roles.map((role, i) => (
        <button
          class={`filter-tag ${i === 0 ? 'is-selected' : ''}`}
          type="button"
          data-role-filter={i === 0 ? '__all' : role.toLowerCase()}
        >
          {role}
        </button>
      ))}
    </div>

    <p class="empty-state" data-empty-state hidden>No matching member found. Try another keyword or role.</p>

    <div class="grid grid-3">
      {members.map((m, i) => (
        <article
          class="card card-hover member-card"
          data-member-card
          data-name={m.name}
          data-role={m.role.en}
          data-area={m.area}
          data-reveal
          data-reveal-delay={String(i * 70)}
        >
          <span class="member-avatar" aria-hidden="true">{initials(m.name)}</span>
          <h3>{m.name}</h3>
          <p class="member-role"><span class="badge-muted">{m.role.en}</span></p>
          <p class="mt-4">{m.area}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
