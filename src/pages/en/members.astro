---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { resolveMemberAvatar } from '../../utils/member-avatar';
import { pickI18nText } from '../../utils/i18n-text';

const memberEntries = await getCollection('members');
const roleOrder = ['PI', 'PhD', 'Master', 'RA'];
const roleRank = new Map(roleOrder.map((role, index) => [role, index]));
const currentStatuses = ['Current', 'Active'];
const formerStatuses = ['Alumni', 'Former'];

function resolveStatusGroup(roleEn: string, statusEn: string) {
  if (roleEn === 'PI') {
    return 0;
  }
  if (currentStatuses.includes(statusEn)) {
    return 1;
  }
  if (formerStatuses.includes(statusEn)) {
    return 2;
  }
  return 1;
}

function resolveStatusTone(statusEn: string) {
  if (formerStatuses.includes(statusEn)) {
    return 'former';
  }
  return 'current';
}

const membersWithId = memberEntries
  .map((e) => ({
    ...e.data,
    id: e.data.id ?? e.slug,
    nameText: pickI18nText(e.data.name, 'en'),
    areaText: pickI18nText(e.data.area, 'en'),
    statusText: pickI18nText(e.data.status, 'en'),
    avatarResolved: resolveMemberAvatar(e.data),
  }))
  .sort((a, b) => {
    const groupA = resolveStatusGroup(a.role.en, a.statusText);
    const groupB = resolveStatusGroup(b.role.en, b.statusText);
    if (groupA !== groupB) {
      return groupA - groupB;
    }
    const rankA = roleRank.get(a.role.en) ?? Number.MAX_SAFE_INTEGER;
    const rankB = roleRank.get(b.role.en) ?? Number.MAX_SAFE_INTEGER;
    return rankA - rankB || a.nameText.localeCompare(b.nameText);
  });
const roles = ['All', ...roleOrder.filter((role) => membersWithId.some((m) => m.role.en === role))];

---
<BaseLayout title="Members" lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">Members</h1>
    <p class="page-subtitle">Search by name/area keywords and refine results by role tags.</p>
  </section>

  <section class="filter-wrap" data-members-filter-root data-reveal>
    <input
      class="filter-input"
      type="search"
      data-member-search
      placeholder="Search name / area / role..."
      aria-label="Search members"
    />

    <div class="filter-tags">
      {roles.map((role, i) => (
        <button
          class={`filter-tag ${i === 0 ? 'is-selected' : ''}`}
          type="button"
          data-role-filter={i === 0 ? '__all' : role.toLowerCase()}
        >
          {role}
        </button>
      ))}
    </div>

    <p class="empty-state" data-empty-state hidden>No matching member found. Try another keyword or role.</p>

    <div class="grid grid-3" data-reveal-group>
      {membersWithId.map((m, i) => (
        <a
          href={`/en/members/${m.id}/`}
          class="card card-hover card-link member-card"
          data-member-card
          data-name={m.nameText}
          data-role={m.role.en}
          data-area={m.areaText}
          data-reveal
          data-reveal-order={String(i)}
        >
          {m.statusText && m.role.en !== 'PI' && (
            <span class={`member-status status-${resolveStatusTone(m.statusText)}`}>{m.statusText}</span>
          )}
          <img
            class="member-avatar"
            src={m.avatarResolved}
            alt={`${m.nameText} avatar`}
            loading="lazy"
            decoding="async"
          />
          <h3>{m.nameText}</h3>
          <p class="member-role"><span class="badge-muted">{m.role.en}</span></p>
          <p class="mt-4">{m.areaText}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
