---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const paperEntries = await getCollection('papers');
const papers = paperEntries
  .map((e) => e.data)
  .sort((a, b) => b.year - a.year || a.title.localeCompare(b.title));
---
<BaseLayout title="Lab Website · Papers" lang="en" pathPrefix="/en">
  <h1>Papers</h1>
  <div class="grid">
    {papers.map(p => (
      <article class="card">
        <h3 style="margin-bottom:6px">{p.title}</h3>
        <p style="margin:0;color:var(--muted)">{p.year} · {p.venue}</p>
      </article>
    ))}
  </div>
</BaseLayout>
