---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const paperEntries = await getCollection('papers');
const papers = paperEntries
  .map((e) => e.data)
  .sort((a, b) => b.year - a.year || a.title.localeCompare(b.title));
---
<BaseLayout title="Lab Website · Papers" lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">Papers</h1>
    <p class="page-subtitle">Publication list with restrained motion and improved reading rhythm.</p>
  </section>

  <div class="grid">
    {papers.map((p, i) => (
      <article class="card card-hover stack-sm" data-reveal data-reveal-delay={String(i * 80)}>
        <h3>{p.title}</h3>
        <p>{p.year} · {p.venue}</p>
      </article>
    ))}
  </div>
</BaseLayout>
