---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const paperEntries = await getCollection('papers');
const papers = paperEntries
  .map((e) => ({ slug: e.slug, ...e.data }))
  .sort((a, b) => b.year - a.year || a.title.localeCompare(b.title));
const pageDesc = 'Browse DoubleDuckLab papers and publication metadata.';
---
<BaseLayout title="Papers" desc={pageDesc} lang="en" pathPrefix="/en">
  <section class="page-head" data-reveal>
    <h1 class="page-title">Papers</h1>
  </section>

  <section class="filter-wrap" data-list-filter-root data-reveal>
    <input
      class="filter-input"
      type="search"
      data-list-search
      placeholder="Search title / authors / venue / year..."
      aria-label="Search papers"
    />
    <p class="empty-state" data-empty-state hidden>No matching paper found. Try another keyword.</p>

    <div class="grid project-grid" data-list-intro>
      {papers.map((p, i) => (
        <a
          href={`/en/papers/${p.slug}/`}
          class="card card-hover card-link stack-sm"
          data-list-intro-item
          {...(i < 8 ? { 'data-list-intro-active': true } : {})}
          data-list-card
          data-search-text={`${p.title} ${p.authors || ''} ${p.venue} ${p.year}`}
        >
          <h3>{p.title}</h3>
          <p>{p.year} · {p.venue}</p>
          {p.authors && <p class="paper-authors">Authors: {p.authors}</p>}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
