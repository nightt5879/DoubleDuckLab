---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { buildLocalizedNews } from '../../../utils/news-localized';
import { summarizeParts } from '../../../utils/seo';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  const localized = buildLocalizedNews(allNews).filter((item) => item.entry.en);

  return localized
    .filter((item) => item.entry.en)
    .map((item) => ({
      params: { slug: item.slug },
      props: {
        entry: item.entry.en!,
        title: item.title.en || item.title.zh || item.slug,
        date: item.date,
        localeAlternates: {
          zh: item.entry.zh ? `/news/${item.slug}/` : undefined,
          en: `/en/news/${item.slug}/`,
          xDefault: item.entry.zh ? `/news/${item.slug}/` : `/en/news/${item.slug}/`,
        },
        related: localized
          .filter((n) => n.slug !== item.slug)
          .slice(0, 3)
          .map((n) => ({
            slug: n.slug,
            date: n.date,
            title: n.title.en || n.title.zh || n.slug,
          })),
      },
    }));
}

const { entry, title, date, related, localeAlternates } = Astro.props;
const { Content } = await render(entry);
const pageDesc = summarizeParts([date, entry.body], 160) || `${title}${date ? ` · ${date}` : ''}`;
---
<BaseLayout title={title} desc={pageDesc} lang="en" pathPrefix="/en" ogType="article" localeAlternates={localeAlternates}>
  <section class="detail-shell">
    <article class="card detail-hero" data-reveal>
      <h1 class="page-title">{title}</h1>
      <div class="detail-meta">
        {date && <span class="badge-muted">{date}</span>}
      </div>
    </article>

    <article class="card detail-content news-article" data-reveal>
      <Content />
    </article>

    <article class="card detail-section" data-reveal>
      <h2>More News</h2>
      <ul class="detail-list">
        {related.map((n) => (
          <li><a href={`/en/news/${n.slug}/`}>{n.title}</a> · {n.date}</li>
        ))}
      </ul>
    </article>

    <div class="back-row" data-reveal>
      <a class="btn btn-primary" href="/en/news/" data-history-back>Back to News</a>
      <a class="btn btn-ghost" href="/en/">Back to Home</a>
    </div>
  </section>
</BaseLayout>
